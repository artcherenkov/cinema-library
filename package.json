{
  "name": "cinema-library",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "build:cloud-function": "node scripts/build-cloud-function-artifact.mjs",
    "typecheck": "pnpm -r typecheck",
    "dev:frontend": "pnpm --filter @cinema-library/frontend dev",
    "dev:backend": "pnpm --filter @cinema-library/backend dev",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "fmt": "pnpm -r fmt",
    "fmt:check": "pnpm -r fmt:check",
    "check": "pnpm lint && pnpm fmt:check && pnpm typecheck"
  },
  "devDependencies": {
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "typescript": "^5.9.0"
  }
}
