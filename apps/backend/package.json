{
  "name": "@cinema-library/backend",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/adapters/local-server.ts",
    "build": "tsup",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/local.js",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt . --check"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@ydbjs/auth": "^6.2.1",
    "@ydbjs/core": "^6.1.1",
    "@ydbjs/query": "^6.1.0",
    "@ydbjs/value": "^6.0.7",
    "hono": "^4.12.18",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.20.0"
  }
}
